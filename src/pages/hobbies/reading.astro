---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { BOOKS } from "../../lib/books";
---

<BaseLayout title="Reading | Dogus Ural">
  <section class="section">
    <div class="container">
      <h1>📚 Reading Shelf</h1>
      <p class="muted">Icon view of books I keep returning to.</p>

      <section class="books-section">
        <h2>📖 Books</h2>
        <ul class="book-grid">
          {BOOKS.map((book) => (
            <li class="book-item">
              <img src={book.cover} alt={`Cover of ${book.title}`} class="book-cover" loading="lazy" decoding="async" />
              <h3>{book.title}</h3>
              <p class="muted">{book.author}</p>
            </li>
          ))}
        </ul>
      </section>

    </div>
  </section>
</BaseLayout>

<style>
  .book-grid {
    list-style: none;
    margin: 1.1rem 0 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
  }

  .book-item {
    border: 1px dashed var(--border);
    border-radius: 0;
    padding: 0.6rem;
    background: color-mix(in srgb, var(--bg-elevated) 24%, transparent);
  }

  .book-cover {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border: 1px dashed var(--border);
    border-radius: 0;
    background: color-mix(in srgb, var(--bg) 82%, black);
  }

  .book-item h3 {
    font-size: 0.9rem;
    margin: 0.55rem 0 0.25rem;
    line-height: 1.3;
  }

  .book-item p {
    margin: 0;
    font-size: 0.82rem;
  }

  .books-section h2 {
    font-size: 1.05rem;
    margin: 1rem 0 0.35rem;
  }
</style>
